{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ssm82/vk-mcp",
  "title": "VK MCP Server",
  "description": "MCP server for VK API with 180+ tools: users, wall, groups, friends, photos, messages.",
  "repository": {
    "url": "https://github.com/ssm82/full-vk-mcp",
    "source": "github"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "full-vk-mcp",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://{host}/mcp",
      "variables": {
        "host": {
          "description": "Your deployed VK MCP server hostname, for example: vk-mcp.your-domain.com",
          "isRequired": true
        }
      },
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer authentication header. Use: Bearer <VK_MCP_AUTH_TOKEN>",
          "isRequired": true,
          "isSecret": true
        }
      ]
    },
    {
      "type": "sse",
      "url": "https://{host}/sse",
      "variables": {
        "host": {
          "description": "Your deployed VK MCP server hostname, for example: vk-mcp.your-domain.com",
          "isRequired": true
        }
      },
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer authentication header. Use: Bearer <VK_MCP_AUTH_TOKEN>",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}